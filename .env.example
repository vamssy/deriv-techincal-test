# Environment template for the stage-gated AI support pipeline.
# Copy this file to .env (which is gitignored), set your real key below, and
# NEVER commit .env or your key. Keep this .env.example free of real secrets.

# NVIDIA NIM API key. When set, `provider: auto` uses NVIDIA NIM with the
# `z-ai/glm-5.2` model; when unset, the pipeline runs on the deterministic mock
# provider (offline, no network, fully reproducible). Leave blank to use mock.
NVIDIA_API_KEY=

# Provider selection: auto | mock | nvidia
#   auto   - (default) NVIDIA if NVIDIA_API_KEY is set, otherwise mock
#   mock   - force the deterministic offline provider (no key, no network)
#   nvidia - force the NVIDIA NIM provider
# PROVIDER=auto
